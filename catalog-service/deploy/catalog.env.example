# dvw-catalog environment. Copy to /opt/dvw-catalog/catalog.env on vossisrv.
# Every value has a built-in default; uncomment only what you need to change.

# Where the catalog + ssh-blueprint live. The systemd unit's ReadWritePaths
# must match this.
#CATALOG_DATA_DIR=/var/lib/dvw-catalog

# Docker connection. Empty/unset => local /var/run/docker.sock (needs the
# `docker` supplementary group). Point at the socket-proxy to drop that group:
#CATALOG_DOCKER_HOST=tcp://127.0.0.1:2375

# Optional bearer token. Leave unset for the SSH+unix-socket auth model
# (recommended for the single-user box). Set it only when more than one
# principal can reach the socket.
#CATALOG_TOKEN=

# Resolver result cache TTL (seconds). 0 disables.
#CATALOG_RESOLVE_CACHE_TTL=8
