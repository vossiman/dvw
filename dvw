#!/usr/bin/env bash
# dvw — DevPod workspace orchestrator. See devpod/README.md.
set -euo pipefail

DVW_ROOT="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
# Optional per-machine config (catalog host / provider). Loaded BEFORE the libs
# so it can set DVW_* values the libs then fall back on. env > file > default.
# shellcheck source=lib/config.sh
. "$DVW_ROOT/lib/config.sh"
dvw_load_config
# shellcheck source=lib/catalog.sh
. "$DVW_ROOT/lib/catalog.sh"
# shellcheck source=lib/ssh-sync.sh
. "$DVW_ROOT/lib/ssh-sync.sh"
# shellcheck source=lib/wsl-bridge.sh
. "$DVW_ROOT/lib/wsl-bridge.sh"
# shellcheck source=lib/connect.sh
. "$DVW_ROOT/lib/connect.sh"
# Service-backed overrides for the resolver/probe functions. MUST come after
# connect.sh so its definitions win.
# shellcheck source=lib/connect-resolver.sh
. "$DVW_ROOT/lib/connect-resolver.sh"
# shellcheck source=lib/commands.sh
. "$DVW_ROOT/lib/commands.sh"
# shellcheck source=lib/wizard.sh
. "$DVW_ROOT/lib/wizard.sh"
# shellcheck source=lib/ui.sh
. "$DVW_ROOT/lib/ui.sh"
# shellcheck source=lib/update-check.sh
. "$DVW_ROOT/lib/update-check.sh"
# shellcheck source=lib/tui-launch.sh
. "$DVW_ROOT/lib/tui-launch.sh"

main() {
  # Pull out --dry-run (anywhere in argv) before subcommand dispatch.
  # Mutating shellouts (devpod up/delete/stop, docker restart) flowing
  # through _dvw_run_or_print print "would run: ..." instead of executing.
  # Direct catalog mutations gate on DVW_DRY_RUN inline.
  local arg filtered=()
  for arg in "$@"; do
    if [[ "$arg" == "--dry-run" ]]; then
      export DVW_DRY_RUN=1
    else
      filtered+=("$arg")
    fi
  done
  set -- "${filtered[@]}"
  if [[ "${DVW_DRY_RUN:-}" == "1" ]]; then
    ui_info "[dry-run] no commands will be executed; would-be invocations are printed"
  fi

  # Update notifier: kick a throttled background fetch, then print the cached
  # "behind main" nudge (suppressed for `dvw update` itself). Fail-open.
  dvw_update_refresh_if_stale
  dvw_update_maybe_nudge "${1:-}"

  # `dvw config` must work even when the catalog is unreachable — it's how you
  # fix a wrong host — so handle it before the reachability gate below.
  if [[ "${1:-}" == config ]]; then
    shift; cmd_config "$@"; return $?
  fi

  ui_progress "checking catalog"        catalog_init_if_missing || exit 1
  ui_progress "syncing ssh blueprint"   ssh_sync_refresh
  ui_progress "syncing wsl bridge"      wsl_bridge_refresh

  case "${1:-}" in
    -l|--list)
      cmd_list ;;
    new)
      shift; cmd_new "$@" ;;
    rm)
      shift; cmd_rm "$@" ;;
    update)
      shift; cmd_update "$@" ;;
    stop)
      shift; cmd_stop "$@" ;;
    start)
      shift; cmd_start "$@" ;;
    recreate|rebuild)
      shift; cmd_recreate "$@" ;;
    status)
      cmd_status ;;
    doctor)
      cmd_doctor ;;
    "")
      if _dvw_tui_available; then
        dvw_tui_launch || ui_top_menu
      else
        command -v uv >/dev/null 2>&1 \
          || ui_info "tip: install uv for the dvw TUI (https://docs.astral.sh/uv/) — falling back to menu"
        ui_top_menu
      fi ;;
    *)
      cmd_connect "$1" ;;
  esac
}

main "$@"
