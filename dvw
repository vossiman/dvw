#!/usr/bin/env bash
# dvw — DevPod workspace orchestrator. See devpod/README.md.
set -euo pipefail

DVW_ROOT="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
# shellcheck source=lib/catalog.sh
. "$DVW_ROOT/lib/catalog.sh"
# shellcheck source=lib/ssh-sync.sh
. "$DVW_ROOT/lib/ssh-sync.sh"
# shellcheck source=lib/wsl-bridge.sh
. "$DVW_ROOT/lib/wsl-bridge.sh"
# shellcheck source=lib/connect.sh
. "$DVW_ROOT/lib/connect.sh"
# shellcheck source=lib/commands.sh
. "$DVW_ROOT/lib/commands.sh"
# shellcheck source=lib/wizard.sh
. "$DVW_ROOT/lib/wizard.sh"
# shellcheck source=lib/ui.sh
. "$DVW_ROOT/lib/ui.sh"

main() {
  # Pull out --dry-run (anywhere in argv) before subcommand dispatch.
  # Mutating shellouts (devpod up/delete/stop, docker restart) flowing
  # through _dvw_run_or_print print "would run: ..." instead of executing.
  # Direct catalog mutations gate on DVW_DRY_RUN inline.
  local arg filtered=()
  for arg in "$@"; do
    if [[ "$arg" == "--dry-run" ]]; then
      export DVW_DRY_RUN=1
    else
      filtered+=("$arg")
    fi
  done
  set -- "${filtered[@]}"
  if [[ "${DVW_DRY_RUN:-}" == "1" ]]; then
    ui_info "[dry-run] no commands will be executed; would-be invocations are printed"
  fi

  # `blueprint` is a pure file copy from this repo's blueprint/ directory
  # into a target repo. It doesn't touch the catalog or need the rclone
  # mount, so it should work even when those are unavailable. Short-circuit
  # before the catalog gate.
  if [[ "${1:-}" == "blueprint" ]]; then
    shift; cmd_blueprint "$@"
    return $?
  fi

  ui_progress "checking catalog"        catalog_init_if_missing || exit 1
  ui_progress "syncing ssh blueprint"   ssh_sync_refresh
  ui_progress "syncing wsl bridge"      wsl_bridge_refresh

  case "${1:-}" in
    -l|--list)
      cmd_list ;;
    new)
      shift; cmd_new "$@" ;;
    rm)
      shift; cmd_rm "$@" ;;
    stop)
      shift; cmd_stop "$@" ;;
    start)
      shift; cmd_start "$@" ;;
    recreate|rebuild)
      shift; cmd_recreate "$@" ;;
    status)
      cmd_status ;;
    doctor)
      cmd_doctor ;;
    "")
      ui_top_menu ;;
    *)
      cmd_connect "$1" ;;
  esac
}

main "$@"
